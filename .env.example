# ---------------------------------------------------------------------------
# SCE International — variables de entorno
# Copia este archivo a `.env.local` y completa los valores.
# NUNCA subas `.env.local` ni claves reales al repositorio.
# En Vercel, configura estas mismas variables en Project Settings → Environment.
# ---------------------------------------------------------------------------

# --- Supabase (Project Settings → API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave de servicio: SOLO en el servidor (server actions / route handlers).
# No anteponer NEXT_PUBLIC_. No exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (correos transaccionales) — https://resend.com ------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="SCE International <no-reply@tu-dominio.com>"

# --- App --------------------------------------------------------------------
# URL pública de la app, usada para construir enlaces en los correos.
NEXT_PUBLIC_APP_URL=http://localhost:3000
